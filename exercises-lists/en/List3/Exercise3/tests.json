{
	"type": "class",
	"class": "Motor",
	"timeout": 1000.0,
	"methods": [
		{
			"name": "get_potencia",
			"cases": [
				{
					"name": "Motor retorna a potencia configurada",
					"constructor_params": [
						200.0
					],
					"expected_output": 200.0
				}
			]
		},
		{
			"name": "ligar",
			"cases": [
				{
					"name": "Motor liga e retorna mensagem adequada",
					"constructor_params": [
						150.0
					],
					"expected_output": "Motor ligado! Potência: 150",
					"properties": {
						"ligado": true
					}
				}
			]
		},
		{
			"name": "ligar_carro",
			"cases": [
				{
					"name": "Carro liga o motor interno",
					"class": "Carro",
					"constructor_params": [
						100.0
					],
					"expected_output": "Motor ligado! Potência: 100"
				}
			]
		},
		{
			"name": "acessar_potencia",
			"cases": [
				{
					"name": "Carro expoe a potencia do motor",
					"class": "Carro",
					"constructor_params": [
						180.0
					],
					"expected_output": 180.0
				}
			]
		}
	]
}
